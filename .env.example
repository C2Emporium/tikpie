DATABASE_URL="postgresql://user:password@localhost:5432/tikpie?schema=public"

# URL du site (pour SEO : sitemap, robots, Open Graph). En prod avec nom de domaine : https://tondomaine.com
# NEXT_PUBLIC_SITE_URL=https://tondomaine.com

# Build Vercel : ajoute SKIP_DB=1 dans Vercel > Settings > Environment Variables, scope "Build" uniquement
# pour que le build ne tente pas de contacter la base (évite exit 1 si DB injoignable au build).
# Ne pas définir en Production/Preview pour que le site utilise la DB à l'exécution.

# Upload en production (Vercel) : créez un Blob Store (Storage > Blob), puis la variable est ajoutée automatiquement
# BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# Pub bannière 300x250 (contenu adulte) – option A : iframe (recommandé)
# Remplacer par l’URL fournie par ton réseau (ExoClick, TrafficJunky, etc.)
# NEXT_PUBLIC_AD_IFRAME_URL=https://a.xxx.com/iframe.php?idzone=TON_ZONE_ID&size=300x250

# Option B : script async (ExoClick)
# NEXT_PUBLIC_AD_SCRIPT_URL=https://a.xxx.com/ads.js
# NEXT_PUBLIC_AD_ZONE_ID=1234567
